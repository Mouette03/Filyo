# Configuration Filyo
# Copiez ce fichier en .env et ajustez les valeurs

# -----------------------------------------------------------------------
# OBLIGATOIRE — à renseigner AVANT le premier lancement
# Sert aussi de clé AES-256-GCM pour chiffrer le mot de passe SMTP en base
# Générer une valeur avec : openssl rand -hex 32
# -----------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-secret

# Port exposé sur l'hôte (le conteneur interne tourne toujours sur 3001)
PORT=3001

# Chemin local pour stocker les données (base de données + uploads)
DATA_PATH=./data

# Niveau de log backend : silent | error | warn | info | debug
LOG_LEVEL=info
