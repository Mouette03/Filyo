# Configuration Filyo
# Copiez ce fichier en .env et ajustez les valeurs

# -----------------------------------------------------------------------
# OBLIGATOIRE — à renseigner AVANT le premier lancement
# Sert aussi de clé AES-256-GCM pour chiffrer le mot de passe SMTP en base
# Générer une valeur avec : openssl rand -hex 32
# -----------------------------------------------------------------------
JWT_SECRET=

# Port exposé sur l'hôte (le conteneur interne tourne toujours sur 3001)
PORT=3001

# Chemin local pour stocker les données (base de données + uploads)
DATA_PATH=./data

# Niveaux émis par le code : debug | info | warn | error
# silent = désactive tout
LOG_LEVEL=info

# Timeout des uploads en ms (défaut : 30 min | min : 1 min | max : 2 h)
# UPLOAD_TIMEOUT_MS=1800000

# -----------------------------------------------------------------------
# OIDC / SSO — laisser vide pour désactiver
# -----------------------------------------------------------------------
# OIDC_ISSUER_URL=https://auth.exemple.com/realms/mon-realm
# OIDC_CLIENT_ID=filyo
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3001/api/auth/oidc/callback
# OIDC_SCOPE=openid email profile
# OIDC_AUTO_REGISTER=auto_register
# OIDC_DEFAULT_ROLE=USER
# OIDC_PROVIDER_NAME=oidc
